{
  "manifest_version": 3,
  "name": "PhishGuard V2 - Auto Shield",
  "version": "2.2",
  "description": "Proactive AI-powered phishing detection.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}