{
  "manifest_version": 3,
  "name": "PhishGuard V2 - Auto Shield",
  "version": "2.2",
  "description": "Proactive AI-powered phishing detection.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"] 
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "phishguard@yourdomain.com",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup.html"
  }
}